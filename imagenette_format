import os
import tarfile
import torchvision.datasets as datasets
from torchvision.transforms import Compose, Resize, ToTensor
from urllib.request import urlretrieve

# ✅ Define constants (Colab-compatible)
IMAGENETTE_URL = "https://s3.amazonaws.com/fast-ai-imageclas/imagenette2-320.tgz"
DATASET_FOLDER = "/content/imagenette_data"

# ✅ Mapping of Imagenette folders to original ImageNet class IDs
IMAGENETTE_CLASS_MAP = {
    "n01440764": 0,    # Fish (Tench)
    "n02102040": 217,  # Dog (English Springer)
    "n02979186": 482,  # Tape Cutter (Cassette Player)
    "n03000684": 491,  # Chain Saw
    "n03028079": 497,  # Church
    "n03394916": 566,  # Musical Instrument (French Horn)
    "n03417042": 569,  # Trash (Garbage Truck)
    "n03425413": 571,  # Gas Pump
    "n03445777": 574,  # Golf Ball
    "n03888257": 701,  # Air Balloon (Parachute)
}

# ✅ Function to download and extract dataset
def download_and_extract(url, dest_folder):
    os.makedirs(dest_folder, exist_ok=True)
    tar_path = os.path.join(dest_folder, os.path.basename(url))
    
    if not os.path.exists(tar_path):
        print(f"Downloading {url}...")
        urlretrieve(url, tar_path)
        print("Download complete!")

    print(f"Extracting {tar_path}...")
    with tarfile.open(tar_path, "r:gz") as tar:
        tar.extractall(path=dest_folder)
    print("Extraction complete!")

# ✅ Download Imagenette
download_and_extract(IMAGENETTE_URL, DATASET_FOLDER)

# ✅ Define dataset paths (only validation set)
dataset_path = os.path.join(DATASET_FOLDER, "imagenette2-320")
val_path = os.path.join(dataset_path, "val")  # Only validation images

# ✅ Load only validation dataset
transform = Compose([Resize((224, 224)), ToTensor()])
imagenette_dataset = datasets.ImageFolder(root=val_path, transform=transform)

# ✅ Save imagenet.txt with only test (validation) images
output_file = os.path.join(DATASET_FOLDER, "imagenet.txt")
with open(output_file, "w") as f:
    for img_path, target in imagenette_dataset.samples:
        folder_name = os.path.basename(os.path.dirname(img_path))  # Extract class folder
        imagenet_label = IMAGENETTE_CLASS_MAP.get(folder_name, -1)  # Get ImageNet label (-1 if not found)
        f.write(f"{img_path} {imagenet_label}\n")

print(f"Generated {output_file} with only test images successfully!")
