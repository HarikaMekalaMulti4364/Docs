def preprocess(image, img_scale=(640, 640), pad_val=(114, 114, 114)):
    """
    Preprocesses an input image for YOLOX model inference.

    Args:
        image (np.ndarray): Original image in RGB.
        img_scale (tuple): Target image size as (width, height).
        pad_val (tuple): Padding value per channel.

    Returns:
        np.ndarray: Preprocessed image tensor of shape (1, 3, H, W).
    """
    h_in, w_in = img_scale
    image = cv2.resize(image, (w_in, h_in), interpolation=cv2.INTER_LINEAR)

    # Convert to float32
    image = image.astype(np.float32)

    # Pad to square if needed
    padded_img = np.full((max(h_in, w_in), max(h_in, w_in), 3), pad_val, dtype=np.float32)
    padded_img[:h_in, :w_in, :] = image

    # Transpose HWC to CHW
    img_data = padded_img.transpose(2, 0, 1)
    img_data = img_data.reshape(1, 3, max(h_in, w_in), max(h_in, w_in))

    return img_data




